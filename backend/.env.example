NODE_ENV=production
PORT=5001
MONGODB_CONNECTIONSTRING=mongodb+srv://username:password@cluster.mongodb.net/productmanager
JWT_SECRET=change-this-secret
CORS_ORIGINS=http://localhost:5173,https://your-frontend-project.vercel.app

VNPAY_TMN_CODE=
VNPAY_SECURE_SECRET=
VNPAY_HOST=https://sandbox.vnpayment.vn
VNPAY_TEST_MODE=true
VNPAY_HASH_ALGORITHM=SHA512
VNPAY_ENABLE_LOG=false
VNPAY_RETURN_URL=https://your-frontend-project.vercel.app/payment/vnpay-return

EMAIL_USER=
EMAIL_PASS=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_FROM_NAME=Cua hang
EMAIL_USE_ETHEREAL=false

GEMINI_API_KEY=

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_USERNAME=admin
STAFF_EMAIL=staff@example.com
STAFF_PASSWORD=staff123
STAFF_USERNAME=staff

# Vercel runs serverless functions, so keep this true there unless you replace
# the background job with Vercel Cron or another scheduler.
DISABLE_ORDER_COMPLETION_CRON=true
